[Unit]
Description=KORA Backend (FastAPI/Uvicorn)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/kora/backend
EnvironmentFile=/opt/kora/backend/.env
ExecStart=/opt/kora/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
