# ═══════════════════════════════════════════════════════════════════
# KORA Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env dans git
# ═══════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,https://kakilambe.com

# ─── LLM Providers ───────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxx
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

LLM_PROVIDER_ORDER=groq,gemini,cerebras,openrouter
LLM_PRIMARY_MODEL=groq/llama-3.3-70b-versatile
LLM_FALLBACK_MODELS=gemini/gemini-2.0-flash,cerebras/llama-3.3-70b,openrouter/meta-llama/llama-3.1-8b-instruct:free

# ─── Base de données (Supabase) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@db.xxxx.supabase.co:5432/postgres

# ─── Cache (Upstash Redis) ────────────────────────────────────────────────────
REDIS_URL=rediss://default:password@xxx.upstash.io:6380

# ─── Collecte ─────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxx

# ─── Génération d'image ───────────────────────────────────────────────────────
IMAGE_GEN_API_KEY=xxxxxxxxxxxxxxxxxxxx
IMAGE_GEN_PROVIDER=fal

# ─── WordPress ────────────────────────────────────────────────────────────────
WP_BASE_URL=https://kakilambe.com
WP_USERNAME=kora_publisher
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── Gmail ────────────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
GMAIL_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxx
GMAIL_RECIPIENT=mistermarcket@gmail.com

# ─── Scheduling ───────────────────────────────────────────────────────────────
CYCLE_HOUR=6
CYCLE_TIMEZONE=Africa/Conakry

# ─── Sécurité ─────────────────────────────────────────────────────────────────
API_SECRET_KEY=xxxxxxxxxxxxxxxxxxxx
ADMIN_SECRET_KEY=xxxxxxxxxxxxxxxxxxxx
