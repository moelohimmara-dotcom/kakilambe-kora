# ─────────────────────────────────────────────────────────────────────────────
# KORA Backend — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs.
# NE JAMAIS committer .env dans git.
# ─────────────────────────────────────────────────────────────────────────────

# Application
DEBUG=false
SECRET_KEY=your_random_secret_key_min_32_chars
ALLOWED_ORIGINS=https://kakilambe.com,http://localhost:3000

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# LLM Providers (chaîne de fallback : groq → gemini → cerebras → openrouter)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CEREBRAS_API_KEY=csk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Recherche
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WordPress (kakilambe.com)
WP_URL=https://kakilambe.com
WP_USER=your_wordpress_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Redis (Upstash ou Redis Cloud)
REDIS_URL=redis://default:xxxxxxxxxxxx@your-redis-host:6379

# Email (rapport quotidien)
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
REPORT_EMAIL=recipient@example.com

# Image generation (fal.ai)
FAL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Scraping avancé (optionnel)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BRIGHTDATA_API_KEY=your_brightdata_api_key
