# ─────────────────────────────────────────────────────────────────────────────
# KORA Frontend — Variables d'environnement Next.js
# Copiez ce fichier en .env.local et remplissez les valeurs.
# NE JAMAIS committer .env.local dans git.
# ─────────────────────────────────────────────────────────────────────────────

# URL du backend FastAPI (sans slash final)
NEXT_PUBLIC_API_URL=https://kora-api.onrender.com

# Clé secrète Super Admin /system (min 32 caractères, jamais exposée côté client)
ADMIN_SECRET_KEY=your_very_long_admin_secret_key_min_32_chars
